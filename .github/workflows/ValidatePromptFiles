### **Suggested Script Enhancements**
Update the Python script (`validate_prompt.py`) to include:
```python
import os
import yaml
import sys

errors = 0

for root, dirs, files in os.walk('.'):
    for file in files:
        if file.endswith('.prompt.yml'):
            path = os.path.join(root, file)
            try:
                with open(path, 'r', encoding='utf-8') as f:
                    data = yaml.safe_load(f)
                    
                    # Check root is a dict
                    if not isinstance(data, dict):
                        print(f"❌ {path}: Root must be a dictionary")
                        errors += 1
                        continue
                    
                    # Enforce "messages" is a list
                    if 'messages' not in data:
                        print(f"❌ {path}: Missing 'messages' key")
                        errors += 1
                    elif not isinstance(data['messages'], list):
                        print(f"❌ {path}: 'messages' must be a list")
                        errors += 1
                    
                    print(f"✅ {path}: Valid")
            
            except yaml.YAMLError as e:
                print(f"❌ {path}: YAML error - {e}")
                errors += 1
            except Exception as e:
                print(f"❌ {path}: Error parsing file - {e}")
                errors += 1

if errors > 0:
    sys.exit(1)
```

